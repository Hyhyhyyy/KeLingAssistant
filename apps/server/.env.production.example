# 生产环境配置示例
# 复制此文件为 .env 并修改相应配置

# Server
PORT=3001
NODE_ENV=production

# JWT - 请在生产环境中更换为安全的密钥
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# DeepSeek AI
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Database (PostgreSQL - Render 会自动设置 DATABASE_URL)
# DATABASE_URL 将由 Render 自动提供